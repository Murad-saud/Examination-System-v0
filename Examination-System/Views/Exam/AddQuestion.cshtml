@model CreateQuestionFormModel

<div class="w-full rounded-lg bg-white p-4 shadow-sm">
    <div class="mb-4 border-b border-slate-200 pb-2">
        <h1 class="text-lg font-semibold text-slate-800">
            Question <span class="text-slate-500">/ Add Question</span>
        </h1>
        <p class="mt-1 text-sm text-slate-500">Add a new question to the exam</p>
    </div>

    <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
        <div class="border-b border-slate-200 bg-slate-100 px-4 py-3">
            <h2 class="font-semibold text-slate-700">Question Details</h2>
        </div>

        <form asp-controller="Exam" asp-action="AddQuestion" method="post" class="p-6">
            <input asp-for="ExamId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="mb-4 text-sm text-red-600"></div>

            <!-- Question -->
            <div class="mb-4">
                <label asp-for="QuestionText" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <textarea asp-for="QuestionText"
                          class="w-full rounded border border-slate-300 p-2 text-sm
                                 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500"
                          placeholder="Type question here..."></textarea>
                <span asp-validation-for="QuestionText" class="text-xs text-red-500"></span>
            </div>

            <!-- Answers -->
            <div id="answers-container" class="mb-4">
                @for (int i = 0; i < 2; i++)
                {
                    <div class="answer-field mb-3">
                        <label class="mb-1 block text-sm font-medium text-slate-700">
                            Answer @(i + 1)
                        </label>
                        <div class="flex items-center">
                            <input name="AnswersText[@i]"
                                   class="w-full rounded border border-slate-300 px-3 py-2 text-sm
                                              outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500"
                                   placeholder="Answer @(i + 1) text..." />
                            <button type="button"
                                    class="remove-answer-btn ml-2 hidden text-red-500 hover:text-red-700">
                                ✕
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="mb-6">
                <button type="button" id="add-answer-btn"
                        class="text-sky-600 hover:text-sky-700">
                    + Add Another Answer
                </button>
            </div>

            <!-- Correct Answer + Weight -->
            <div class="grid grid-cols-1 gap-6 border-t border-slate-200 pt-4 md:grid-cols-2">
                <div>
                    <label asp-for="IndexOfCorrectAnswer"
                           class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <select asp-for="IndexOfCorrectAnswer"
                            id="correct-answer-select"
                            class="w-full rounded border border-slate-300 p-2 text-sm
                                   outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500">
                        <option value="">-- Choose Correct Answer --</option>
                        <option value="1">Answer 1</option>
                        <option value="2">Answer 2</option>
                    </select>
                    <span asp-validation-for="IndexOfCorrectAnswer" class="text-xs text-red-500"></span>
                </div>

                <div>
                    <label asp-for="QuestionWeight"
                           class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <input asp-for="QuestionWeight" type="number"
                           class="w-full rounded border border-slate-300 p-2 text-sm
                                  outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500"
                           placeholder="e.g. 2" />
                    <span asp-validation-for="QuestionWeight" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="flex justify-end gap-3 border-t border-slate-200 pt-4">
                <button type="reset"
                        class="rounded border border-slate-300 px-4 py-2 text-sm hover:bg-slate-100">
                    Reset
                </button>
                <button type="submit"
                        class="rounded bg-sky-600 px-5 py-2 text-sm font-medium text-white
                               hover:bg-sky-700 focus:ring-1 focus:ring-sky-300">
                    Submit
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('answers-container');
            const addBtn = document.getElementById('add-answer-btn');
            const select = document.getElementById('correct-answer-select');

            function rebuild() {
                const fields = container.querySelectorAll('.answer-field');
                select.innerHTML = '<option value="">-- Choose Correct Answer --</option>';

                fields.forEach((f, i) => {
                    const displayIndex = i + 1;

                    f.querySelector('label').textContent = `Answer ${displayIndex}`;

                    const input = f.querySelector('input');
                    input.name = `AnswersText[${i}]`;
                    input.placeholder = `Answer ${displayIndex} text...`;

                    const option = document.createElement('option');
                    option.value = displayIndex; // ✅ 1-BASED
                    option.textContent = `Answer ${displayIndex}`;
                    select.appendChild(option);

                    const removeBtn = f.querySelector('.remove-answer-btn');
                    removeBtn.classList.toggle('hidden', fields.length <= 2);
                    removeBtn.onclick = () => {
                        f.remove();
                        select.value = '';
                        rebuild();
                    };
                });
            }

            addBtn.onclick = () => {
                if (container.children.length >= 6) return;

                const div = document.createElement('div');
                div.className = 'answer-field mb-3';
                div.innerHTML = `
                    <label class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <div class="flex items-center">
                        <input class="w-full rounded border border-slate-300 px-3 py-2 text-sm
                                      outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500" />
                        <button type="button"
                                class="remove-answer-btn ml-2 text-red-500 hover:text-red-700">✕</button>
                    </div>
                `;
                container.appendChild(div);
                rebuild();
            };

            rebuild();
        });
    </script>
}
