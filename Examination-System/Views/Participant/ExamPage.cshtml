@model ExamPageDto

@{
    Layout = "_Empty";
}

@{
    var pageSize = Model.PageQuestions.Count;
    int qCounter = pageSize * (Model.CurrentPage - 1) + 1;

    string isChecked(int questionId, int answerId)
    {
        if (Model.SavedAnswers.TryGetValue(questionId, out int value))
        {
            if (value == answerId)
                return "checked";
        }
        return "";
    }
}

<main class="min-h-screen bg-gray-100 p-6 md:p-10">
    <div class="w-full rounded-lg bg-white p-4 shadow-md">

        <!-- Exam Header -->
        <div class="mb-6 rounded-md border border-slate-200 bg-white p-6">
            <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center">
                <div>
                    <h1 class="text-lg font-semibold text-slate-800">CS Fundamentals</h1>
                    <p class="mt-1 text-sm text-slate-500">Answer all questions before time expires</p>
                </div>

                <!-- Timer -->
                <div class="rounded border border-red-200 bg-red-50 px-4 py-3">
                    <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-sm font-medium text-red-700">Time Remaining:</span>
                        <span id="timer" class="font-mono text-lg font-bold text-red-800">--:--</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Form -->
        <form asp-controller="Participant" asp-action="NavigateExamPage" method="post" id="navigation-form">
            <input type="hidden" name="pageNumber" value="@Model.CurrentPage" id="current-page-input" />
            <input type="hidden" name="participantExamId" value="@Model.ParticipantExamId" />

            <!-- Questions Container -->
            <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
                <!-- Questions Header -->
                <div class="flex items-center justify-between bg-slate-100 px-4 py-3">
                    <h2 class="font-semibold text-slate-700">Questions</h2>
                    <span class="text-sm text-slate-500">Page <span id="current-page">@Model.CurrentPage</span> of <span id="total-pages">@Model.TotalPages</span></span>
                </div>

                <!-- Questions Content -->
                <div class="space-y-8 p-6">
                    @for (int i = 0; i < Model.PageQuestions.Count; i++)
                    {
                        var question = Model.PageQuestions[i];

                        <div class="question-container">
                            <!-- Hidden QuestionId for EVERY question -->
                            <input type="hidden"
                                   name="saveAnswers[@i].QuestionId"
                                   value="@question.QuestionId" />

                            <div class="mb-4">
                                <h3 class="text-lg font-medium text-slate-800">
                                    <span class="mr-2 rounded bg-slate-100 px-2 py-1 text-sm text-slate-700">
                                        @qCounter
                                    </span>
                                    @question.QuestionText
                                </h3>
                            </div>

                            <!-- Answers Loop -->
                            <div class="ml-6 space-y-2">
                                @foreach (var answer in question.Answers)
                                {
                                    <div class="flex items-center">
                                        @{
                                            bool isChecked = Model.SavedAnswers.ContainsKey(question.QuestionId)
                                            && Model.SavedAnswers[question.QuestionId] == answer.AnswerId;
                                        }

                                        <input type="radio"
                                               id="answer_@answer.AnswerId"
                                               name="saveAnswers[@i].SelectedAnswerId"
                                               value="@answer.AnswerId"
                                               class="peer hidden"
                                               @(isChecked ? "checked" : "") />

                                        <label for="answer_@answer.AnswerId" class="flex w-full cursor-pointer items-center rounded border border-slate-300 p-3 text-slate-700 transition peer-checked:border-sky-600 peer-checked:bg-sky-50">
                                            <span class="mr-3 flex h-5 w-5 items-center justify-center rounded border border-slate-400 peer-checked:border-sky-600 peer-checked:bg-sky-600">
                                                <svg class="hidden h-3 w-3 text-white peer-checked:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                                </svg>
                                            </span>
                                            @answer.AnswerText
                                        </label>
                                    </div>
                                }
                                <!-- End of Answers Loop -->
                                <!-- Hidden radio for "no selection" -->
                                <input type="radio"
                                       name="saveAnswers[@i].SelectedAnswerId"
                                       value="0"
                                       class="hidden"
                                       @(!Model.SavedAnswers.ContainsKey(question.QuestionId) ? "checked" : "") />
                            </div>
                        </div>

                        qCounter++;
                    }
                    <!-- End of Questions Loop -->
                </div>

                <!-- Navigation & Action Buttons -->
                <div class="flex flex-col items-center justify-between gap-4 border-t border-slate-200 p-4 md:flex-row">
                    <!-- Navigation Buttons -->
                    <div class="flex w-full gap-3 md:w-auto">
                        <button type="button" id="prev-btn"
                                class="flex w-full items-center justify-center rounded border border-slate-300 px-4 py-2 text-sm text-slate-700 transition hover:bg-slate-100 md:w-auto @(Model.CurrentPage == 1 ? "opacity-50 cursor-not-allowed" : "")"
                                @(Model.CurrentPage == 1 ? "disabled" : "")>
                            <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                            </svg>
                            Previous Page
                        </button>

                        <button type="button" id="next-btn"
                                class="flex w-full items-center justify-center rounded bg-sky-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-sky-700 focus:ring-1 focus:ring-sky-300 md:w-auto @(Model.CurrentPage == Model.TotalPages ? "opacity-50 cursor-not-allowed" : "")"
                                @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")>
                            Next Page
                            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </button>
                    </div>

                    <!-- Page Indicator -->
                    <div class="w-full text-center text-sm text-slate-600 md:w-auto">
                        Page <span id="current-page-bottom">@Model.CurrentPage</span> of <span id="total-pages-bottom">@Model.TotalPages</span>
                    </div>

                    <!-- Submit Button -->
                    <button type="button" id="submit-btn" class="w-full rounded bg-green-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-green-700 focus:ring-1 focus:ring-green-300 md:w-auto">
                        Submit Exam
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Separate Submit Form -->
    <form asp-controller="Participant" asp-action="SubmitExam" method="post" id="submit-form" style="display: none;">
        <input type="hidden" name="participantExamId" value="@Model.ParticipantExamId" />

        @for (int i = 0; i < Model.PageQuestions.Count; i++)
        {
            var question = Model.PageQuestions[i];
            <input type="hidden" name="saveAnswers[@i].QuestionId" value="@question.QuestionId" />
            <input type="hidden" name="saveAnswers[@i].SelectedAnswerId" id="submit-answer-@question.QuestionId" value="0" />
        }
    </form>

    <input type="hidden" id="exam-end-time" value="@Model.EndTime.ToUniversalTime().ToString("o")" />

</main>

<script>
    (function () {
        // ============================
        // Time Remaining Logic
        // ============================
        const endTimeInput = document.getElementById("exam-end-time");
        const timerEl = document.getElementById("timer");

        const examEndUtc = new Date(endTimeInput.value).getTime();

        function formatTime(seconds) {
            const h = Math.floor(seconds / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = seconds % 60;

            return `${h.toString().padStart(2, "0")}:${m.toString().padStart(2, "0")}:${s.toString().padStart(2, "0")}`;
        }

        function updateTimer() {
            const nowUtc = new Date().getTime();
            const remainingMs = examEndUtc - nowUtc;

            if (remainingMs <= 0) {
                timerEl.textContent = "00:00:00";
                autoSubmit();
                return;
            }

            const remainingSeconds = Math.floor(remainingMs / 1000);
            timerEl.textContent = formatTime(remainingSeconds);
        }

        setInterval(updateTimer, 1000);
        updateTimer();

        // ============================
        // Navigation Logic
        // ============================
        const navForm = document.getElementById("navigation-form");
        const pageInput = document.getElementById("current-page-input");

        document.getElementById("prev-btn")?.addEventListener("click", function () {
            pageInput.value = parseInt(pageInput.value) - 1;
            navForm.submit();
        });

        document.getElementById("next-btn")?.addEventListener("click", function () {
            pageInput.value = parseInt(pageInput.value) + 1;
            navForm.submit();
        });

        // ============================
        // Submit Logic
        // ============================
        const submitBtn = document.getElementById("submit-btn");
        const submitForm = document.getElementById("submit-form");

        submitBtn.addEventListener("click", function () {
            submitForm.submit();
        });

        function autoSubmit() {
            submitForm.submit();
        }
    })();
</script>
