@model List<AvailableExamVM>

<!-- Main content area -->
<div class="w-full rounded-lg bg-white p-4 shadow-sm">
    <!-- Page header -->
    <div class="mb-4 border-b border-slate-200 pb-2">
        <h1 class="text-lg font-semibold text-slate-800">Available Exams</h1>
        <p class="mt-1 text-sm text-slate-500">View all Scheduled and In Progress exams for Participant</p>
    </div>

    <!-- Simplified Filter Section -->
    
    <!-- Exams Table -->
    <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
        <!-- Box header -->
        <div class="flex items-center justify-between bg-slate-100 px-4 py-2">
            <h2 class="text-sm font-medium text-slate-700">Exams List</h2>
            <span class="text-xs text-slate-500">@Model.Count exams found</span>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            @if (Model.Count > 0)
            {
                <table class="w-full text-left text-sm">
                    <!-- Table Header -->
                    <thead class="bg-slate-50 text-slate-700">
                        <tr>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">#</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Exam Title</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Course</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Instructor</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Status</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Start Date</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Duration</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Actions</th>
                        </tr>
                    </thead>

                    <!-- Table Body -->
                    <tbody>
                        @{
                            int counter = 1;
                            foreach (var exam in Model)
                            {
                                <tr class="border-b border-slate-200 hover:bg-slate-50">
                                    <td class="px-3 py-2">@counter</td>
                                    <td class="px-3 py-2 font-medium text-slate-800">@exam.ExamTitle</td>
                                    <td class="px-3 py-2">@exam.CourseName</td>
                                    <td class="px-3 py-2">@exam.InstructorName</td>
                                    <td class="px-3 py-2">
                                        @{
                                            var statusClass = exam.ExamStatus.ToLower() switch
                                            {
                                                "scheduled" => "bg-blue-100 text-blue-800",
                                                "inprogress" => "bg-green-100 text-green-800",
                                                _ => "bg-gray-100 text-gray-800"
                                            };
                                        }
                                        <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium @statusClass">
                                            @exam.ExamStatus
                                        </span>
                                    </td>
                                    <td class="px-3 py-2">@exam.StartDate.ToString("dd/MM/yyyy, HH:mm")</td>
                                    <td class="px-3 py-2">@exam.Duration</td>
                                    <td class="px-3 py-2">
                                        @if (exam.ExamStatus.ToLower() == "inprogress")
                                        {
                                            <a asp-controller="Participant" asp-action="JoinExam" asp-route-examId="@exam.ExamId"
                                               class="text-shadow text-shadow-md text-sm font-semibold tracking-wider text-green-500 duration-100 hover:text-green-700">
                                                    Join
                                            </a>
                                        }
                                        else
                                        {
                                            <p class="cursor-default text-xs text-gray-400">Wait for start</p>
                                        }
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                    </tbody>
                </table>

                <!-- Pagination -->
                <div class="mt-4 flex items-center justify-between px-4 py-2">
                    <div class="text-xs text-slate-600">
                        Showing 1 to @Model.Count of @Model.Count entries
                    </div>
                    <div class="flex space-x-2">
                        <button class="rounded border border-slate-300 px-2 py-1 text-xs text-slate-700 hover:bg-slate-100">
                            Previous
                        </button>
                        <button class="rounded bg-sky-600 px-2 py-1 text-xs font-medium text-white">
                            1
                        </button>
                        <button class="rounded border border-slate-300 px-2 py-1 text-xs text-slate-700 hover:bg-slate-100">
                            Next
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="mx-auto w-full py-6 text-center text-sm text-slate-600">No exams found</div>
            }
        </div>
    </div>
</div>