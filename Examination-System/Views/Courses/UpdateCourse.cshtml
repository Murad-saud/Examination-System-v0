@using Examination_System.ViewModels.Course
@model UpdateCourseVM

<div class="w-full rounded-lg bg-white p-4 shadow-sm">
    <!-- Page header -->
    <div class="mb-4 border-b border-slate-200 pb-2">
        <h1 class="text-lg font-semibold text-slate-800">Course <span class="text-slate-500">/ Update Course</span></h1>
        <p class="mt-1 text-sm text-slate-500">Update course information</p>
    </div>

    <!-- Content box -->
    <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
        <!-- Box header -->
        <div class="border-b border-slate-200 bg-slate-100 px-4 py-3">
            <h2 class="font-semibold text-slate-700">Course Details</h2>
        </div>

        <!-- Form body -->
        <form asp-controller="Courses" asp-action="UpdateCourse" method="post" class="p-6">
            <input asp-for="@Model.FormInputs.CourseId" hidden />
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <!-- Course Name -->
                <div>
                    <label asp-for="@Model.FormInputs.CourseName" class="mb-1 block text-sm font-medium text-slate-700">Course Name</label>
                    <input asp-for="@Model.FormInputs.CourseName" type="text" placeholder="e.g. Artificial Intelligence"
                           class="w-full rounded border border-slate-300 p-2 text-sm text-slate-800 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500">
                    <span asp-validation-for="@Model.FormInputs.CourseName" class="text-xs text-red-500"></span>
                </div>

                <!-- Instructor -->
                <div>
                    <label asp-for="@Model.FormInputs.InstructorId" class="mb-1 block text-sm font-medium text-slate-700">Instructor</label>
                    <select asp-for="@Model.FormInputs.InstructorId"
                            class="w-full rounded border border-slate-300 p-2 text-sm text-slate-800 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500">
                        @foreach (var instructor in Model.AllInstructors!)
                        {
                            if (instructor.Id == Model.CourseInstructor.Id)
                            {
                                <option value="@instructor.Id" selected>@instructor.FullName</option>
                                continue;
                            }
                            <option value="@instructor.Id">@instructor.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="@Model.FormInputs.InstructorId" class="text-xs text-red-500"></span>
                </div>
            </div>

            <!-- Action buttons -->
            <div class="flex justify-end gap-3 border-t border-slate-200 pt-4">
                <button type="reset"
                        class="rounded border border-slate-300 px-4 py-2 text-sm text-slate-700 transition hover:bg-slate-100">
                    Reset
                </button>
                <button type="submit"
                        class="rounded bg-sky-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-sky-700 focus:ring-1 focus:ring-sky-300">
                    Submit
                </button>
            </div>
        </form>
    </div>
</div>