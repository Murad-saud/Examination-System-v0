

<div class="mb-4 flex w-full flex-wrap gap-4 text-black md:flex-nowrap">
    <!-- Search by -->
    <div class="flex min-w-[200px] flex-1 items-center gap-2">
        <label for="searchBy" class="whitespace-nowrap text-base font-medium text-slate-700">Search By:</label>
        <select id="searchBy" class="w-full flex-1 rounded-md border border-slate-400 bg-blue-50 px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500">
            <option value="">Name</option>
            <option value="">Email Address</option>
            <option value="">Phone Number</option>
        </select>
    </div>

    <!-- Sort by -->
    <div class="flex min-w-[200px] flex-1 items-center gap-2">
        <label for="sortBy" class="whitespace-nowrap text-base font-medium text-slate-700">Sort By:</label>
        <select id="sortBy" class="w-full flex-1 rounded-md border border-slate-400 bg-blue-50 px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500">
            <option value="">Ascending</option>
            <option value="">Descending</option>
        </select>
    </div>

    <!-- Search input -->
    <div class="flex min-w-[200px] flex-1 items-center gap-2">
        <label for="input" class="whitespace-nowrap text-base font-medium text-slate-700">Input:</label>
        <input type="text" id="input" placeholder="Type here" class="w-full flex-1 rounded-md border border-slate-400 bg-blue-50 px-3 py-2 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500">
    </div>

    <!-- Submit button -->
    <div class="min-w-[200px] flex-1">
        <button type="submit" class="w-full rounded-md bg-sky-700 px-4 py-2 text-white transition-colors duration-200 hover:bg-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2">Submit</button>
    </div>
</div>