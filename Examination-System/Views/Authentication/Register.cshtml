@{
    Layout = "_Empty";
}

@using Examination_System.ViewModels
@using Examination_System.Helpers.Constants;
@model RegisterVM

    <div class="min-h-screen bg-gradient-to-br from-sky-800 via-sky-600 to-sky-400">
        <!-- Container -->
        <div class="flex min-h-screen flex-col items-center justify-center">
            <!-- Card Container -->
            <form asp-controller="Authentication" asp-action="Register" class="w-[400px] rounded-md bg-gray-50 p-4 shadow-md">
                <div class="flex flex-col">
                    <!-- Header -->
                    <h1 class="mx-auto px-20 text-4xl font-bold text-blue-500">
                        Sign Up
                    </h1>
                    <div class="mx-6 mb-6 mt-3 h-1 bg-blue-500"></div>
                    <!-- Names Forms -->
                    <div class="flex items-center justify-between">
                        <!-- First Name Input -->
                        <div class="flex max-w-[31%] flex-col space-y-1">
                            <label for="firstName" class="mx-auto text-sm font-medium text-slate-600">First Name</label>
                            <input asp-for="@Model.FirstName" type="text" id="firstName"
                                   class="rounded-sm border border-sky-100 px-2 py-1 text-center shadow-sm outline-none placeholder:text-slate-400 focus:border-2 focus:border-sky-500"
                                   placeholder="A">
                        </div>
                        <!-- Second Name Input -->
                        <div class="flex max-w-[31%] flex-col space-y-1">
                            <label for="secondName" class="mx-auto text-sm font-medium text-slate-600">Second Name</label>
                            <input asp-for="@Model.MiddleName" type="text" id="secondName"
                                   class="rounded-sm border border-sky-100 px-2 py-1 text-center shadow-sm outline-none placeholder:text-slate-400 focus:border-2 focus:border-sky-500"
                                   placeholder="B">
                        </div>
                        <div class="flex max-w-[31%] flex-col space-y-1">
                            <label for="lastName" class="mx-auto text-sm font-medium text-slate-600">Last Name</label>
                            <input asp-for="@Model.LastName" type="text" id="lastName"
                                   class="rounded-sm border border-sky-100 px-2 py-1 text-center shadow-sm outline-none placeholder:text-slate-400 focus:border-2 focus:border-sky-500"
                                   placeholder="C">
                        </div>
                    </div>

                    <!-- Email Address -->
                    <div class="mt-2 flex flex-col space-y-1">
                        <label for="email" class="mx-auto text-sm font-medium text-slate-600">Email Address</label>
                        <input asp-for="@Model.EmailAdress" type="email" id="email"
                               class="rounded-sm border border-sky-100 px-2 py-1 text-center shadow-sm outline-none placeholder:text-slate-400 focus:border-2 focus:border-sky-500"
                               placeholder="example@website.com">
                    </div>

                    <!-- Date of Birth -->
                    <div class="flex items-center justify-center space-x-2">
                        <!-- left line -->
                        <div class="-mb-8 h-0.5 w-16 bg-blue-500 opacity-10"></div>
                        <div class="mt-2 flex flex-col space-y-1">
                            <label for="dateOfBirth" class="mx-auto text-sm font-medium text-slate-600">Date Of Birth</label>
                            <input asp-for="@Model.DateOfBirth" type="date" id="dateOfBirth"
                                   class="rounded-sm border border-sky-100 px-2 py-1 text-center text-slate-400 shadow-sm outline-none focus:border-2 focus:border-sky-500">
                        </div>
                        <!-- right line -->
                        <div class="-mb-8 h-0.5 w-16 bg-blue-500 opacity-10"></div>
                    </div>

                    <!-- Passwords -->
                    <div class="mt-2 flex min-w-full items-center justify-center space-x-5">
                        <!-- Password Field -->
                        <div class="flex max-w-[47%] flex-col space-y-1">
                            <label for="password" class="mx-auto text-sm font-medium text-slate-600">Password</label>
                            <input asp-for="@Model.Password" type="password" id="password"
                                   class="rounded-sm border border-sky-100 px-2 py-1 text-center text-slate-600 shadow-sm outline-none placeholder:text-slate-400 focus:border-2 focus:border-sky-500"
                                   placeholder="******">
                        </div>
                        <!-- Confirm Password Field -->
                        <div class="flex max-w-[47%] flex-col space-y-1">
                            <label for="confirmPassword" class="mx-auto text-sm font-medium text-slate-600">Confirm Password</label>
                            <input asp-for="@Model.ConfirmPassword" type="password" id="confirmPassword"
                                   class="rounded-sm border border-sky-100 px-2 py-1 text-center text-slate-600 shadow-sm outline-none placeholder:text-slate-400 focus:border-2 focus:border-sky-500"
                                   placeholder="******">
                        </div>
                    </div>

                <!-- Select Role -->
                <div class="mt-2">
                    <label class="text-sm font-medium text-zinc-500" for="selection">Select your role: </label>
                    <select asp-for="@Model.RoleName" class="rounded-sm px-2 text-sm text-slate-500 outline-none focus:border-2 focus:border-sky-500"
                           id="selectin">
                        <option value="@RoleNames.Admin">Admin</option>
                        <option value="@RoleNames.Instructor">Instructor</option>
                        <option value="@RoleNames.Participant">Participant</option>
                    </select>
                </div>

                <div asp-validation-summary="All" class="my-2 text-sm text-red-500"></div>
                 
                    <button type="submit" class="mt-6 border-2 border-blue-500 bg-blue-500 py-2 text-gray-50 duration-100 hover:bg-opacity-0 hover:text-blue-600">Sign Up</button>


                </div>
            </form>
        </div>
    </div>
