@model List<ExamSummaryVM>

<!-- Main content area -->
<div class="w-full rounded-lg bg-white p-4 shadow-sm">
    <!-- Page header -->
    <div class="mb-4 border-b border-slate-200 pb-2">
        <h1 class="text-lg font-semibold text-slate-800">Admin <span class="text-slate-500">/ Pending Exams</span></h1>
        <p class="mt-1 text-sm text-slate-500">Review and manage pending exam approvals</p>
    </div>

    <!-- Exams Table -->
    <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
        <!-- Box header -->
        <div class="flex items-center justify-between bg-slate-100 px-4 py-2">
            <h2 class="text-sm font-medium text-slate-700">Exams List</h2>
            <span class="text-xs text-slate-500">@Model.Count exams found</span>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            @if (Model.Count > 0)
            {
                <table class="w-full text-left text-sm">
                    <!-- Table Header -->
                    <thead class="bg-slate-50 text-slate-700">
                        <tr>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">#</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Title</th>
                            <th class="hidden border-b border-slate-200 px-3 py-2 font-medium md:table-cell">Instructor</th>
                            <th class="hidden border-b border-slate-200 px-3 py-2 font-medium md:table-cell">Course</th>
                            <th class="hidden border-b border-slate-200 px-3 py-2 font-medium lg:table-cell">Start Date</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Q Count</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Duration(Minutes)</th>
                            <th class="border-b border-slate-200 px-3 py-2 font-medium">Action</th>
                        </tr>
                    </thead>

                    <!-- Table Body -->
                    <tbody>
                        @{
                            int counter = 1;
                            foreach (var exam in Model)
                            {
                                <tr class="border-b border-slate-200 hover:bg-slate-50">
                                    <td class="px-3 py-2">@counter</td>
                                    <td class="px-3 py-2 font-medium text-slate-800">@exam.ExamTitle</td>
                                    <td class="hidden px-3 py-2 md:table-cell">@exam.InstructorName</td>
                                    <td class="hidden px-3 py-2 md:table-cell">@exam.CourseName</td>
                                    <td class="hidden px-3 py-2 lg:table-cell">@exam.StartDate</td>
                                    <td class="px-3 py-2">@exam.QuestionsCount</td>
                                    <td class="px-3 py-2">@exam.Duration</td>
                                    <td class="px-3 py-2">
                                        <div class="flex space-x-2">
                                            <a asp-controller="Admin" asp-action="ExamApproval"
                                               asp-route-examId="@exam.ExamId" asp-route-isApproved="@true"
                                               class="text-xs text-sky-600 hover:text-sky-800">
                                                Approve
                                            </a>
                                            <a asp-controller="Admin" asp-action="ExamApproval"
                                               asp-route-examId="@exam.ExamId" asp-route-isApproved="@false"
                                               class="text-xs text-red-600 hover:text-red-800">
                                                Reject
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                    </tbody>
                </table>

                <!-- Pagination -->
                <div class="mt-4 flex items-center justify-between px-4 py-2">
                    <div class="text-xs text-slate-600">
                        Showing 1 to @Model.Count of @Model.Count entries
                    </div>
                    <div class="flex space-x-2">
                        <button class="rounded border border-slate-300 px-2 py-1 text-xs text-slate-700 hover:bg-slate-100">
                            Previous
                        </button>
                        <button class="rounded bg-sky-600 px-2 py-1 text-xs font-medium text-white">
                            1
                        </button>
                        <button class="rounded border border-slate-300 px-2 py-1 text-xs text-slate-700 hover:bg-slate-100">
                            Next
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="mx-auto w-full py-6 text-center text-sm text-slate-600">No pending exams found</div>
            }
        </div>
    </div>
</div>